    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["-p1", "COM7", "-p2", "COM4"],
            "env": {
                    "PYTHONUNBUFFERED": "1",
                    "TERM": "dumb" 
                    }
        }
    ]
}